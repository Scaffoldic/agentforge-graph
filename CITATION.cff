repository-code: "https://github.com/Scaffoldic/agentforge-graph"
url: "https://pypi.org/project/agentforge-graph/"
license: Apache-2.0
keywords:
  - code-knowledge-graph
  - knowledge-graph
  - code-search
  - static-analysis
  - tree-sitter
  - mcp
  - ai-agents
  - retrieval-augmented-generation
